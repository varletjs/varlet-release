{
  "compilerOptions": {
    "target": "esnext",
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["esnext"],
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./lib",
    "isolatedDeclarations": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
