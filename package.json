{
  "name": "@varlet/release",
  "version": "1.1.0",
  "description": "publish all packages, generate changelogs and check commit messages",
  "keywords": [
    "changelog",
    "commit-lint",
    "release",
    "varlet"
  ],
  "bugs": "https://github.com/varletjs/release/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varletjs/release"
  },
  "license": "MIT",
  "author": "clencat <2091927351@qq.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "vr": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "commit-lint": "node dist/cli.js commit-lint",
    "dev": "tsdown --watch",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "release": "pnpm build && vitest run && node scripts/release.js",
    "release:dev": "pnpm build && node scripts/release.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --allow-empty --concurrent false",
    "commit-msg": "pnpm run commit-lint -p $1"
  },
  "lint-staged": {
    "*.{md}": "prettier --write",
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "package.json": "prettier --write"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^11.1.0",
    "conventional-changelog": "^5.1.0",
    "rslog": "^2.1.1",
    "semver": "^7.7.4",
    "tinyexec": "^1.1.1"
  },
  "devDependencies": {
    "@configurajs/eslint": "^0.1.2",
    "@configurajs/prettier": "^0.1.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/conventional-changelog": "^3.1.5",
    "@types/node": "^22.14.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=10.0"
  }
}
