{
  "name": "@varlet/release",
  "version": "0.4.4",
  "description": "publish all packages, generate changelogs and check commit messages",
  "keywords": [
    "changelog",
    "commit-lint",
    "release",
    "varlet"
  ],
  "bugs": "https://github.com/varletjs/release/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varletjs/release"
  },
  "license": "MIT",
  "author": "clencat <2091927351@qq.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "vr": "bin/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf node_modules dist",
    "commit-lint": "node bin/index.js commit-lint",
    "dev": "tsdown --watch",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "release": "pnpm build && node bin/index.js release -c",
    "type-check": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --allow-empty --concurrent false",
    "commit-msg": "pnpm run commit-lint -p $1"
  },
  "lint-staged": {
    "*.{md}": "prettier --write",
    "*.{ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "commander": "^11.1.0",
    "conventional-changelog": "^5.1.0",
    "fs-extra": "^11.3.3",
    "rslog": "^2.0.0",
    "semver": "^7.5.4",
    "tinyexec": "^1.0.2"
  },
  "devDependencies": {
    "@configurajs/eslint": "^0.1.2",
    "@configurajs/prettier": "^0.1.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/conventional-changelog": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "@types/semver": "^7.5.5",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=10.0"
  }
}
